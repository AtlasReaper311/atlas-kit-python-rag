# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=atlas_rag

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_STRATEGY=recursive

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=info
